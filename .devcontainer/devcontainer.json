// GitHub Codespaces + VS Code "Reopen in Container" config for ml-lab.
//
// Click "Create codespace on main" on github.com/thekaveh/ml-lab and ~2-3 min
// later you have a JupyterLab in the browser with all 21 active notebooks
// runnable — including image_classification-mnist-ffnn-numpy (the one with
// sibling .py imports), because the repo auto-clones into /workspaces/ml-lab
// and the kernel sees those files natively (no bind-mount wrapper needed).
//
// See README.md §3.4 for full motivation, scenarios, and limitations.
{
  "name": "ml-lab",
  "image": "mcr.microsoft.com/devcontainers/python:3.11-bookworm",

  // The Make target is the single source of truth for the install recipe so
  // the local-venv (§3.3), Docker (§3.2), and Codespaces (§3.4) paths all
  // land the same dep set in the same order. See Makefile `codespace-setup`.
  "postCreateCommand": "make codespace-setup",

  // 8888 is the fallback for users running `jupyter lab` manually inside the
  // codespace; GitHub's "Open in JupyterLab" UI feature does its own port
  // forwarding and does not depend on this list.
  "forwardPorts": [8888],

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-cell-tags",
        "ms-toolsai.jupyter-keymap",
        "ms-toolsai.jupyter-renderers"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "jupyter.notebookFileRoot": "${workspaceFolder}"
      }
    }
  }
}
